{
  "schema_name": "canonical_trips",
  "version": "1.0",
  "description": "Unified canonical schema for NYC TLC trip records (yellow, green, fhvhv)",
  "columns": [
    {"name": "trip_id", "type": "string", "description": "Unique trip identifier (SHA-256 hash)"},
    {"name": "service_type", "type": "string", "description": "Service type: yellow, green, fhvhv"},
    {"name": "vendor_id", "type": "int", "description": "TPEP provider code"},
    {"name": "pickup_datetime", "type": "timestamp", "description": "Date and time of pickup"},
    {"name": "dropoff_datetime", "type": "timestamp", "description": "Date and time of dropoff"},
    {"name": "passenger_count", "type": "int", "description": "Number of passengers"},
    {"name": "trip_distance", "type": "double", "description": "Trip distance in miles"},
    {"name": "pickup_location_id", "type": "int", "description": "Taxi zone pickup location ID"},
    {"name": "dropoff_location_id", "type": "int", "description": "Taxi zone dropoff location ID"},
    {"name": "payment_type", "type": "int", "description": "Payment method code"},
    {"name": "fare_amount", "type": "double", "description": "Fare amount"},
    {"name": "extra_amount", "type": "double", "description": "Extra charges"},
    {"name": "mta_tax", "type": "double", "description": "MTA tax"},
    {"name": "tip_amount", "type": "double", "description": "Tip amount"},
    {"name": "tolls_amount", "type": "double", "description": "Tolls amount"},
    {"name": "improvement_surcharge", "type": "double", "description": "Improvement surcharge"},
    {"name": "total_amount", "type": "double", "description": "Total amount paid"},
    {"name": "congestion_surcharge", "type": "double", "description": "Congestion surcharge"},
    {"name": "airport_fee", "type": "double", "description": "Airport fee"},
    {"name": "year", "type": "int", "description": "Partition year"},
    {"name": "month", "type": "int", "description": "Partition month"},
    {"name": "source_file", "type": "string", "description": "Original source filename"},
    {"name": "ingestion_timestamp", "type": "timestamp", "description": "Timestamp when data was ingested"},
    {"name": "quality_status", "type": "string", "description": "Quality status: PENDING, VALID, SUSPICIOUS"}
  ],
  "homologation": {
    "pickup_datetime": {"yellow": "tpep_pickup_datetime", "green": "lpep_pickup_datetime", "fhvhv": "pickup_datetime"},
    "dropoff_datetime": {"yellow": "tpep_dropoff_datetime", "green": "lpep_dropoff_datetime", "fhvhv": "dropoff_datetime"},
    "pickup_location_id": {"yellow": "PULocationID", "green": "PULocationID", "fhvhv": "PULocationID"},
    "dropoff_location_id": {"yellow": "DOLocationID", "green": "DOLocationID", "fhvhv": "DOLocationID"},
    "vendor_id": {"yellow": "VendorID", "green": "VendorID", "fhvhv": "VendorID"},
    "fare_amount": {"yellow": "fare_amount", "green": "fare_amount", "fhvhv": "base_passenger_fare"},
    "tip_amount": {"yellow": "tip_amount", "green": "tip_amount", "fhvhv": "tips"},
    "tolls_amount": {"yellow": "tolls_amount", "green": "tolls_amount", "fhvhv": "tolls"},
    "extra_amount": {"yellow": "extra", "green": "extra", "fhvhv": null},
    "mta_tax": {"yellow": "mta_tax", "green": "mta_tax", "fhvhv": null},
    "improvement_surcharge": {"yellow": "improvement_surcharge", "green": "improvement_surcharge", "fhvhv": null}
  }
}
